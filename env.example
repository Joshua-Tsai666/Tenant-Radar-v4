# ════════════════════════════════════════════════════════
# 租客雷達 v4 — 環境變數範本
# 本檔案可以上傳 GitHub（沒有真實金鑰）
# 真實金鑰填在 Railway Dashboard → Variables
# ════════════════════════════════════════════════════════

# Railway 會自動提供 PORT，不需要手動設定
PORT=3001

# ── Gemini AI（必填）────────────────────────────────────
# 免費取得：https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ── Facebook Graph API（選填）───────────────────────────
# 申請：https://developers.facebook.com/
# 需要 groups_access_member_info 權限
FB_ACCESS_TOKEN=your_facebook_access_token_here
FB_GROUP_IDS=社團ID1,社團ID2

# ── 您的出租物件（JSON 格式）────────────────────────────
# 修改成您自己的物件資料
MY_PROPS=[{"area":"信義區","price":38000,"type":"2房","tags":["含家具","近捷運","可養寵物"]},{"area":"南港區","price":28000,"type":"套房","tags":["近捷運"]}]
